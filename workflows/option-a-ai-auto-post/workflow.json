          },
          {
            "node": "Instagram Graph API \u2014 Create Media",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Facebook Graph API \u2014 Create Post": {
      "main": [
        [
          {
            "node": "Aggregate Results (Code)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Instagram Graph API \u2014 Create Media": {
      "main": [
        [
          {
            "node": "Aggregate Results (Code)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Aggregate Results (Code)": {
      "main": [
        [
          {
            "node": "Log to Google Sheets",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Log to Google Sheets": {
      "main": [
        [
          {
            "node": "Telegram Notify",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "callerPolicy": "workflowsFromSameOwner",
    "availableInMCP": false
  },
  "staticData": null,
  "active": false
}